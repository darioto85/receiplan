{% extends 'base.html.twig' %}

{% block title %}Liste de courses{% endblock %}

{% block body %}
  <div
    data-controller="shopping"
    data-shopping-toggle-url-value="{{ path('shopping_toggle', { id: 0 }) }}"
    data-shopping-validate-url-value="{{ path('shopping_validate_cart') }}"
    data-shopping-clear-url-value="{{ path('shopping_clear') }}"
    data-shopping-update-quantity-url-value="{{ path('shopping_update_quantity', { id: 0 }) }}"
    data-shopping-update-unit-url-value="{{ path('shopping_update_unit', { id: 0 }) }}"
    data-shopping-upsert-url-value="{{ path('shopping_upsert') }}"
    data-shopping-csrf-token-value="{{ csrf_token('shopping_cart') }}"
  >
    <div class="d-flex justify-content-between align-items-center mb-3 gap-2">
      <h1 class="mb-0">
        <img class="rp-title-thumb" src="{{ asset('img/actions/courses.png') }}" alt="">
        Courses
      </h1>

      {# Desktop #}
      <div class="d-none d-md-flex align-items-center gap-1 flex-wrap rp-zone-bouton-shopping">
        <button
          class="btn btn-primary d-flex align-items-center gap-2"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#shoppingUpsertForm"
          aria-controls="shoppingUpsertForm"
        >
          <img class="bt-action-thumb" src="{{ asset('img/actions/stock_add.png') }}" alt="">
          <span>Ajouter manuellement</span>
        </button>

        <button
          type="button"
          class="btn btn-outline-primary d-flex align-items-center gap-2"
          data-bs-toggle="modal"
          data-bs-target="#shoppingGenerateModal"
          title="Générer ma liste de courses"
        >
          <img class="bt-action-thumb" src="{{ asset('img/actions/generer_courses.png') }}" alt="">
          <span>Générer ma liste</span>
        </button>

        <button
          type="button"
          class="btn btn-primary d-flex align-items-center gap-2"
          data-shopping-target="validateBtn"
          data-action="shopping#validateCart"
          disabled
          title="Valider les produits cochés et les ajouter au stock"
        >
          <img class="bt-action-thumb" src="{{ asset('img/actions/caddie.png') }}" alt="">
          <span>Valider mon caddie</span>
        </button>

        <button
          type="button"
          class="btn btn-outline-danger d-flex align-items-center gap-2"
          data-bs-toggle="modal"
          data-bs-target="#shoppingClearModal"
          title="Vider toute la liste de courses"
        >
          <span><img src="{{ asset('img/actions/delete.png') }}" alt="" class="bt-action-thumb"></span>
          <span>Vider la liste</span>
        </button>
      </div>

      {# Mobile #}
      <div class="dropdown d-md-none">
        <button
          class="btn btn-primary d-flex align-items-center gap-2"
          type="button"
          data-bs-toggle="dropdown"
          aria-expanded="false"
          title="Actions"
        >
          <span>Actions</span>
          <span>⋯</span>
        </button>

        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
          <li>
            <button
              class="dropdown-item d-flex align-items-center gap-2"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#shoppingUpsertForm"
              aria-controls="shoppingUpsertForm"
            >
              <img class="bt-action-thumb" src="{{ asset('img/actions/stock_add.png') }}" alt="">
              Ajouter manuellement
            </button>
          </li>

          <li>
            <button
              type="button"
              class="dropdown-item d-flex align-items-center gap-2"
              data-bs-toggle="modal"
              data-bs-target="#shoppingGenerateModal"
            >
              <img class="bt-action-thumb" src="{{ asset('img/actions/generer_courses.png') }}" alt="">
              Générer ma liste
            </button>
          </li>

          <li>
            <button
              type="button"
              class="dropdown-item d-flex align-items-center gap-2"
              data-shopping-target="validateBtn"
              data-action="shopping#validateCart"
              disabled
            >
              <img class="bt-action-thumb" src="{{ asset('img/actions/caddie.png') }}" alt="">
              Valider mon caddie
            </button>
          </li>

          <li><hr class="dropdown-divider"></li>

          <li>
            <button
              type="button"
              class="dropdown-item d-flex align-items-center gap-2 text-danger"
              data-bs-toggle="modal"
              data-bs-target="#shoppingClearModal"
            >
              <span><img src="{{ asset('img/actions/delete.png') }}" alt="" class="bt-action-thumb"></span>
              Vider la liste
            </button>
          </li>
        </ul>
      </div>
    </div>

    <div id="shoppingUpsertForm" class="collapse mb-4">
      <div class="mb-2" data-shopping-target="formErrors"></div>

      {{ include('common/_ingredient_quickadd_form.html.twig', {
        form: form,
        action: path('shopping_upsert'),
        submit_action: 'submit->shopping#submitUpsert',
        search_url: path('stock_ingredient_search'),
        detail_url: path('stock_ingredient_get')
      }) }}
    </div>

    <div data-shopping-target="listing">
      {{ include('shopping/_listing.html.twig', { items: items, categories: categories }) }}
    </div>

    <div class="modal fade" id="shoppingClearModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

          <div class="modal-header">
            <h5 class="modal-title d-flex align-items-center gap-2">
              <span><img src="{{ asset('img/actions/delete.png') }}" alt="" class="bt-action-thumb"></span>
              Vider la liste
            </h5>

            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Fermer"
            ></button>
          </div>

          <div class="modal-body">
            <p class="mb-2">
              Tu es sûr de vouloir vider toute ta liste de courses ?
            </p>

            <p class="text-muted small mb-0">
              Cette action supprimera tous les articles de la liste.
            </p>
          </div>

          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-outline-primary"
              data-bs-dismiss="modal"
            >
              Annuler
            </button>

            <button
              type="button"
              class="btn btn-outline-danger d-flex align-items-center gap-2"
              data-action="shopping#clearCart"
            >
              <span><img src="{{ asset('img/actions/delete.png') }}" alt="" class="bt-action-thumb"></span>
              Confirmer
            </button>
          </div>

        </div>
      </div>
    </div>

    <div class="modal fade" id="shoppingGenerateModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

          <div class="modal-header">
            <h5 class="modal-title d-flex align-items-center gap-2">
              <img class="bt-action-thumb" src="{{ asset('img/actions/generer_courses.png') }}" alt="">
              Générer ma liste
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
          </div>

          <form
            method="post"
            action="{{ path('shopping_generate') }}"
            data-action="submit->shopping#submitGenerate"
          >
            <div class="modal-body">
              <input type="hidden" name="_token" value="{{ csrf_token('shopping_generate') }}">

              <div class="d-grid gap-2">
                <label class="card shadow-sm border-0 p-3 mb-0" style="cursor:pointer;">
                  <div class="d-flex align-items-start gap-3">
                    <input class="form-check-input mt-1" type="radio" name="mode" value="all" checked>
                    <div>
                      <div class="fw-semibold">Toutes mes recettes</div>
                      <div class="text-muted small">
                        Ingrédients manquants pour l’ensemble de tes recettes.
                      </div>
                    </div>
                  </div>
                </label>

                <label class="card shadow-sm border-0 p-3 mb-0" style="cursor:pointer;">
                  <div class="d-flex align-items-start gap-3">
                    <input class="form-check-input mt-1" type="radio" name="mode" value="favorites">
                    <div>
                      <div class="fw-semibold">Mes recettes favorites</div>
                      <div class="text-muted small">
                        Liste basée uniquement sur tes recettes ⭐ favorites.
                      </div>
                    </div>
                  </div>
                </label>

                <label class="card shadow-sm border-0 p-3 mb-0" style="cursor:pointer;">
                  <div class="d-flex align-items-start gap-3">
                    <input class="form-check-input mt-1" type="radio" name="mode" value="week">
                    <div>
                      <div class="fw-semibold">La semaine qui vient</div>
                      <div class="text-muted small">
                        Ingrédients manquants pour tes repas planifiés à venir.
                      </div>
                    </div>
                  </div>
                </label>
              </div>
            </div>

            <div class="modal-footer">
              <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
              <button type="submit" class="btn btn-primary d-flex align-items-center gap-2">
                <img class="bt-action-thumb" src="{{ asset('img/actions/generer_courses.png') }}" alt="">
                Générer
              </button>
            </div>
          </form>

        </div>
      </div>
    </div>

    {{ include('common/_modal-ingredient.html.twig') }}

  </div>
{% endblock %}