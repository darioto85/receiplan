{{ include('common/_category_filter.html.twig', {
  categories: categories,
  controller: 'shopping',
  filter_prefix: 'shopping'
}) }}

<div
  class="{% if items is not empty %}d-none{% endif %} text-center text-muted py-4"
  data-shopping-target="emptyState"
>
  Ta liste de courses est vide 🧘‍♀️
</div>

<div class="d-grid gap-2 d-md-none" data-shopping-target="mobileList">
  {% for item in items %}
    {{ include('shopping/_shopping_item.html.twig', { item: item, variant: 'mobile', first: loop.first }) }}
  {% endfor %}
</div>

<div class="table-responsive d-none d-md-block">
  <table class="table table-hover mb-0 align-middle">
    <thead class="table-light">
      <tr>
        <th style="width: 44px;"></th>
        <th>Ingrédient</th>
        <th class="text-nowrap" style="width: 140px;">Quantité</th>
        <th>Unité</th>
        <th class="text-end">Actions</th>
      </tr>
    </thead>

    <tbody data-shopping-target="desktopTbody">
      {% for item in items %}
        {{ include('shopping/_shopping_item.html.twig', { item: item, variant: 'desktop' }) }}
      {% endfor %}
    </tbody>
  </table>
</div>