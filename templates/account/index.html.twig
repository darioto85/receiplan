{% extends 'base.html.twig' %}

{% block title %}Mon compte — {{ parent() }}{% endblock %}

{% block body %}
  {% set user = user_entity ?? app.user %}
  {% set display_timezone = 'Europe/Paris' %}
  {% set now_ts = 'now'|date('U') %}
  {% set trial_end_ts = user.trialEndsAt ? user.trialEndsAt|date('U') : null %}
  {% set db_premium_end_ts = user.subscriptionCurrentPeriodEndAt ? user.subscriptionCurrentPeriodEndAt|date('U') : null %}
  {% set manual_premium_end_ts = user.manualPremiumEndsAt ? user.manualPremiumEndsAt|date('U') : null %}
  {% set trial_days_left = trial_end_ts and trial_end_ts > now_ts ? ((trial_end_ts - now_ts) / 86400)|round(0, 'ceil') : 0 %}
  {% set premium_days_left = db_premium_end_ts and db_premium_end_ts > now_ts ? ((db_premium_end_ts - now_ts) / 86400)|round(0, 'ceil') : 0 %}
  {% set manual_premium_days_left = manual_premium_end_ts and manual_premium_end_ts > now_ts ? ((manual_premium_end_ts - now_ts) / 86400)|round(0, 'ceil') : 0 %}

  {% set cancel_at_period_end = stripe_cancel_at_period_end is not null ? stripe_cancel_at_period_end : user.subscriptionCancelAtPeriodEnd %}
  {% set current_period_end_at = stripe_current_period_end_at ?? user.subscriptionCurrentPeriodEndAt %}
  {% set next_billing_at = stripe_next_billing_at ?? user.subscriptionCurrentPeriodEndAt %}

  <div class="d-flex align-items-center justify-content-between mt-3 mb-3">
    <div>
      <h1 class="h4 mb-1">Mon compte</h1>
      <div class="text-body-secondary small">Gère ton profil et ton abonnement.</div>
    </div>
  </div>

  <div class="row g-3 pb-5">

    {# ===================== NAV ===================== #}
    <aside class="col-12 col-lg-3">
      <div class="card">
        <div class="card-body">
          <div style="position: sticky; top: 90px;">
            <div class="list-group">
              <a class="list-group-item list-group-item-action" href="#profil">Profil</a>
              <a class="list-group-item list-group-item-action" href="#premium">Abonnement</a>
              <a class="list-group-item list-group-item-action" href="#notifications">Notifications</a>
              <a class="list-group-item list-group-item-action" href="#securite">Sécurité</a>
            </div>

            <div class="mt-3 d-grid">
              <a class="btn btn-outline-danger" href="{{ path('app_logout') }}">
                Se déconnecter
              </a>
            </div>
          </div>
        </div>
      </div>
    </aside>

    {# ===================== CONTENU ===================== #}
    <section class="col-12 col-lg-9">
      <div class="card">
        <div class="card-body">

          <style>
            .rp-anchor {
              scroll-margin-top: 110px;
            }
          </style>

          {# ===================== PROFIL ===================== #}
          <div id="profil" class="rp-anchor">
            <h2 class="h5 mb-1">Profil</h2>
            <p class="text-body-secondary small">Informations principales.</p>

            <hr class="my-3">

            <div class="row g-3">
              <div class="col-12 col-md-6">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" value="{{ user.email }}" disabled>
              </div>

              <div class="col-12 col-md-6">
                <label class="form-label">Statut email</label>
                {% if user.isVerified %}
                  <div class="alert alert-success mb-0">Email confirmé ✅</div>
                {% else %}
                  <div class="alert alert-warning mb-0">Email non confirmé</div>
                {% endif %}
              </div>
            </div>
          </div>

          <hr class="my-4">

          {# ===================== PREMIUM ===================== #}
          <div id="premium" class="rp-anchor">
            <h2 class="h5 mb-1">Abonnement</h2>
            <p class="text-body-secondary small">Ton accès premium.</p>

            <hr class="my-3">

            {% if user.getPremiumSource() == 'stripe' %}

              {% if cancel_at_period_end %}
                <div class="alert alert-warning mb-3">
                  <div class="fw-semibold mb-1">Résiliation prévue</div>
                  <div class="small">
                    {% if current_period_end_at %}
                      Ton accès premium reste actif jusqu’au
                      <strong>{{ current_period_end_at|date('d/m/Y', display_timezone) }}</strong>.
                      {% if premium_days_left > 0 %}
                        Il te reste encore <strong>{{ premium_days_left }} jour{% if premium_days_left > 1 %}s{% endif %}</strong>.
                      {% endif %}
                    {% else %}
                      Ton abonnement ne sera pas renouvelé.
                    {% endif %}
                  </div>
                </div>
              {% else %}
                <div class="alert alert-success mb-3">
                  <div class="fw-semibold mb-1">Premium actif ✅</div>
                  <div class="small">
                    {% if user.premiumActivatedAt %}
                      Activé le <strong>{{ user.premiumActivatedAt|date('d/m/Y à H:i', display_timezone) }}</strong>.
                    {% else %}
                      Ton accès premium est actif.
                    {% endif %}
                  </div>
                </div>
              {% endif %}

              <div class="border rounded p-3 bg-light-subtle">
                <div class="small mb-2">
                  {% if user.billingPeriod %}
                    Formule :
                    <strong>
                      {% if user.billingPeriod == 'month' %}
                        Mensuelle
                      {% elseif user.billingPeriod == 'year' %}
                        Annuelle
                      {% else %}
                        {{ user.billingPeriod }}
                      {% endif %}
                    </strong>
                  {% endif %}

                  {% if next_billing_at and not cancel_at_period_end %}
                    {% if user.billingPeriod %} — {% endif %}
                    Prochain prélèvement le
                    <strong>{{ next_billing_at|date('d/m/Y', display_timezone) }}</strong>
                  {% endif %}

                  {% if formatted_amount %}
                    {% if user.billingPeriod or next_billing_at %} — {% endif %}
                    <strong>{{ formatted_amount }}</strong>
                  {% endif %}
                </div>

                {% if not cancel_at_period_end %}
                  <a href="{{ path('premium_cancel_subscription') }}"
                     class="btn btn-outline-danger btn-sm">
                    Résilier l’abonnement
                  </a>
                {% else %}
                  <div class="small text-muted">
                    Ton abonnement ne sera pas renouvelé.
                  </div>
                {% endif %}
              </div>

            {% elseif user.getPremiumSource() == 'manual' %}

              <div class="alert alert-success mb-3">
                <div class="fw-semibold mb-1">Accès premium offert 🎁</div>
                <div class="small">
                  {% if user.manualPremiumIsLifetime %}
                    Tu bénéficies actuellement d’un accès premium offert sans limite de durée.
                  {% else %}
                    {% if user.manualPremiumEndsAt %}
                      Ton accès premium offert est actif jusqu’au <strong>{{ user.manualPremiumEndsAt|date('d/m/Y à H:i', display_timezone) }}</strong>.
                      {% if manual_premium_days_left > 0 %}
                        Il te reste encore <strong>{{ manual_premium_days_left }} jour{% if manual_premium_days_left > 1 %}s{% endif %}</strong>.
                      {% endif %}
                    {% else %}
                      Ton accès premium offert est actif.
                    {% endif %}
                  {% endif %}
                </div>
              </div>

            {% elseif user.getPremiumSource() == 'trial' %}

              <div class="alert alert-warning mb-3">
                <div class="fw-semibold mb-1">Essai des fonctionnalités premium ✨</div>
                <div class="small">
                  {% if user.trialEndsAt %}
                    Tu peux tester les fonctionnalités premium jusqu’au <strong>{{ user.trialEndsAt|date('d/m/Y à H:i', display_timezone) }}</strong>.
                    {% if trial_days_left > 0 %}
                      Il te reste encore <strong>{{ trial_days_left }} jour{% if trial_days_left > 1 %}s{% endif %}</strong> pour en profiter.
                    {% endif %}
                    <br>
                    Kuko restera utilisable gratuitement ensuite.
                  {% else %}
                    Tu testes actuellement les fonctionnalités premium.
                    <br>
                    Kuko restera utilisable gratuitement ensuite.
                  {% endif %}
                </div>
              </div>

              <a href="{{ path('premium_index') }}" class="btn btn-success btn-sm">
                Passer au Premium
              </a>

            {% else %}

              <div class="alert alert-light border mb-3">
                <div class="fw-semibold mb-1">Plan gratuit</div>
                <div class="small">
                  Tu n’as pas encore d’accès premium actif.
                </div>
              </div>

              <a href="{{ path('premium_index') }}" class="btn btn-success btn-sm">
                Devenir Premium
              </a>

            {% endif %}
          </div>

          <hr class="my-4">

          {# ===================== NOTIFICATIONS ===================== #}
          <div id="notifications" class="rp-anchor">
            <h2 class="h5 mb-1">Notifications</h2>
            <p class="text-body-secondary small">Push et rappels.</p>

            <hr class="my-3">

            <div
              class="border rounded p-3"
              data-controller="push-toggle"
              data-push-toggle-vapid-public-key-value="{{ vapid_public_key }}"
              data-push-toggle-subscribe-url-value="{{ path('push_subscribe') }}"
              data-push-toggle-unsubscribe-url-value="{{ path('push_unsubscribe') }}"
            >
              <div class="d-flex align-items-center justify-content-between">
                <div>
                  <div class="fw-semibold">Notifications push</div>
                  <div class="text-muted small" data-push-toggle-target="status">Chargement…</div>
                </div>

                <input
                  class="form-check-input"
                  type="checkbox"
                  data-push-toggle-target="toggle"
                  data-action="push-toggle#toggleChanged"
                >
              </div>
            </div>
          </div>

          <hr class="my-4">

          {# ===================== SÉCURITÉ ===================== #}
          <div id="securite" class="rp-anchor">
            <h2 class="h5 mb-1">Sécurité</h2>
            <p class="text-body-secondary small">Mot de passe et accès.</p>

            <hr class="my-3">

            <div class="row g-3">
              <div class="col-12 col-md-6">
                <a class="btn btn-outline-dark w-100"
                   href="{{ path('account_change_password') }}">
                  Réinitialiser le mot de passe
                </a>
              </div>

              <div class="col-12 col-md-6">
                <a class="btn btn-outline-danger w-100"
                   href="{{ path('app_logout') }}">
                  Se déconnecter
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

  </div>
{% endblock %}