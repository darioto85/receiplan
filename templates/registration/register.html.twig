<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <title>{% block title %}KuKo{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    {# Font (comme base.html.twig) #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,200..1000;1,200..1000&display=swap" rel="stylesheet">

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    {% block stylesheets %}
      <link rel="stylesheet" href="{{ asset('styles/styles.css') }}">
    {% endblock %}

    {% block javascripts %}
      {{ importmap('app') }}
    {% endblock %}
  </head>

  <body>
    <div class="container">
      {% if app.request.query.get('reset') %}
        <div class="alert alert-success mt-2">
          Mot de passe mis à jour. Tu peux te connecter.
        </div>
      {% endif %}

      <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">

          {# ✅ Logo + nom (repris du header) #}
          <div class="text-center mb-3">
            <a href="{{ path('meal_plan_index') }}" class="rp-brand d-inline-flex align-items-center gap-2 text-decoration-none">
              <img class="rp-brand-mark" src="{{ asset('img/logo.png') }}" alt="">
              <span class="rp-brand-name">Kuko</span>
            </a>
          </div>

          <div class="card shadow-sm">
            <div class="card-body p-4">

              
<div class="container py-3 py-md-4" style="max-width: 720px;">
  <div class="mb-3">
    <h1 class="h3 mb-1">Créer un compte</h1>
    <div class="text-body-secondary">
      Accède à ton stock, tes recettes et ton assistant.
    </div>
  </div>

  {# OAuth buttons (tu brancheras les routes plus tard) #}
  {#
  <div class="d-grid gap-2 mb-3">
    <a class="btn btn-outline-dark" href="{{ path('connect_google_start') }}">
        Continuer avec Google
    </a>
    
    </div>


  <div class="text-center text-body-secondary small mb-3">
    — ou —
  </div>
  #}

  {{ form_start(form) }}
    <div class="mb-3">
      {{ form_label(form.email, 'Email', {'label_attr': {'class': 'form-label'}}) }}
      {{ form_widget(form.email, {'attr': {'class': 'form-control', 'autocomplete': 'email', 'inputmode': 'email'}}) }}
      {{ form_errors(form.email) }}
    </div>

    <div class="mb-3">
      {{ form_label(form.plainPassword, 'Mot de passe', {'label_attr': {'class': 'form-label'}}) }}
      {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control', 'autocomplete': 'new-password'}}) }}
      <div class="form-text">Minimum 8 caractères.</div>
      {{ form_errors(form.plainPassword) }}
    </div>

    <div class="d-grid">
      <button type="submit" class="btn btn-primary btn-lg">
        Créer mon compte
      </button>
    </div>
  {{ form_end(form) }}

  <div class="card mt-3">
    <div class="card-body">
        <div class="row align-items-center g-3">
        <div class="col-12 col-md-6">
            <div class="fw-semibold">Vous avez déjà un compte ?</div>
            <div class="text-body-secondary small">
            Connectez-vous pour retrouver votre stock et vos recettes.
            </div>
        </div>

        <div class="col-12 col-md-6 text-md-end">
            <div class="d-grid d-md-inline-block">
            <a href="{{ path('app_login') }}" class="btn btn-outline-primary">
                Se connecter
            </a>
            </div>
        </div>
        </div>
    </div>
    </div>

  <div class="text-body-secondary small mt-3">
    En créant un compte, tu acceptes les conditions d’utilisation de Kuko.
  </div>
</div>

            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Bootstrap JS -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
  </body>
</html>






