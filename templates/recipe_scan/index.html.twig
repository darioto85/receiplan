{% extends 'base.html.twig' %}

{% block title %}Scanner une recette{% endblock %}

{% block body %}

  <h1 class="mb-0">
    <img class="rp-title-thumb" src="{{ asset('img/actions/photo.png') }}" alt="">
    Scanner une recette
  </h1>
  <div class="rp-scan-sub">Ajoute une ou plusieurs photos. Kuko s’occupe du reste.</div>
  <div class="rp-scan-note">Rien n’est enregistré sans ton accord.</div>

  {# ===== ZONE UPLOAD ===== #}
  <div class="rp-scan-body">
    <form method="post"
          action="{{ path('recipe_scan_upload') }}"
          enctype="multipart/form-data"
          class="rp-scan-form"
          id="rp-scan-form">
      <input type="hidden" name="_token" value="{{ csrf_token('recipe_scan_upload') }}">

      {# Zone “drop” cliquable #}
      <label class="rp-scan-drop" for="rp-scan-photo" id="rp-scan-drop">
        <div class="rp-scan-illus" aria-hidden="true">
          <div class="rp-scan-illus-fallback">
            <img
              id="rp-scan-illus-img"
              src="{{ asset('img/actions/charger_recette.jpg') }}"
              data-empty-src="{{ asset('img/actions/charger_recette.jpg') }}"
              data-filled-src="{{ asset('img/actions/recette_chargee.jpg') }}"
              alt=""
            />
          </div>
        </div>

        <div class="rp-scan-drop-title" id="rp-scan-title">Dépose une ou plusieurs photos de la recette</div>
        <div class="rp-scan-drop-sub" id="rp-scan-sub">ou prends-les directement avec ton téléphone</div>

        <div class="rp-scan-hint" id="rp-scan-hint">
          Astuce : pour une recette sur plusieurs pages, ajoute toutes les photos dans l’ordre 💚
        </div>

        <div class="rp-scan-file" id="rp-scan-file" hidden>
          <span class="rp-scan-file-badge">✅ Photos prêtes</span>
          <span class="rp-scan-file-name" id="rp-scan-file-name"></span>
        </div>
      </label>

      <input
        id="rp-scan-photo"
        class="rp-scan-input"
        type="file"
        name="photos[]"
        accept="image/*"
        capture="environment"
        multiple
        required
      >

      <div class="rp-scan-actions">
        <button type="submit" class="btn btn-primary rp-scan-btn" id="rp-scan-submit" disabled>
          Analyser la recette
        </button>
      </div>
    </form>

    {% if last_upload %}
      <div class="rp-scan-divider"></div>

      <div class="rp-scan-uploaded">
        <div class="rp-scan-uploaded-meta">
          <div class="rp-scan-uploaded-title">
            Dernières photos envoyées
            {% if last_upload.count is defined %}
              ({{ last_upload.count }})
            {% endif %}
          </div>

          {% if last_upload.files is defined and last_upload.files is iterable %}
            <div class="rp-scan-uploaded-files">
              {% for file in last_upload.files %}
                <div class="rp-scan-uploaded-file text-truncate">
                  {{ loop.index }}. {{ file.originalName }}
                </div>
              {% endfor %}
            </div>
          {% elseif last_upload.originalName is defined %}
            <div class="rp-scan-uploaded-file text-truncate">{{ last_upload.originalName }}</div>
          {% endif %}

          <div class="rp-scan-uploaded-info">
            {{ last_upload.uploadedAt }}
          </div>
        </div>

        <div class="rp-scan-uploaded-cta">
          <form method="post" action="{{ path('recipe_scan_analyze') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('recipe_scan_analyze') }}">
            <button class="btn btn-success rp-scan-btn">
              🤖 Analyser
            </button>
          </form>

          <form method="post" action="{{ path('recipe_scan_reset') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('recipe_scan_reset') }}">
            <button class="btn btn-outline-danger rp-scan-btn">
              🗑️ Supprimer
            </button>
          </form>
        </div>
      </div>
    {% endif %}
  </div>

  {# ===== BOTTOM "manual" ===== #}
  <div class="rp-scan-footer">
    <div class="rp-scan-footer-label">Tu préfères faire autrement ?</div>
    <a href="{{ path('recipe_wizard_new') }}" class="rp-scan-pill">
      <span class="rp-scan-pill-ico" aria-hidden="true">✏️</span>
      Saisir la recette manuellement
    </a>
  </div>

  {# ===== MODALE ERREUR SCAN ===== #}
  {% if scan_error_modal %}
    <div
      class="rp-modal-backdrop is-open"
      id="rp-scan-error-modal"
      aria-hidden="false"
    >
      <div
        class="rp-modal-card"
        role="dialog"
        aria-modal="true"
        aria-labelledby="rp-scan-error-title"
        aria-describedby="rp-scan-error-message"
      >
        <button
          type="button"
          class="rp-modal-close"
          id="rp-scan-error-close-top"
          aria-label="Fermer"
        >
          ×
        </button>

        <div class="rp-modal-icon" aria-hidden="true">⚠️</div>

        <h2 class="rp-modal-title" id="rp-scan-error-title">
          {{ scan_error_modal.title|default('Analyse impossible') }}
        </h2>

        <div class="rp-modal-subtitle">
          Kuko n’a pas réussi à comprendre les photos.
        </div>

        <div class="rp-modal-box">
          <div class="rp-modal-message" id="rp-scan-error-message">
            {{ scan_error_modal.raw_message|default('Une erreur inconnue est survenue.') }}
          </div>
        </div>

        <div class="rp-modal-actions">
          <button type="button" class="btn btn-outline-secondary rp-modal-btn" id="rp-scan-error-cancel">
            Annuler
          </button>
          <button type="button" class="btn btn-primary rp-modal-btn" id="rp-scan-error-retry">
            Recommencer
          </button>
        </div>
      </div>
    </div>
  {% endif %}

  <script>
    (function () {
      const input = document.getElementById('rp-scan-photo');
      const drop = document.getElementById('rp-scan-drop');
      const img = document.getElementById('rp-scan-illus-img');
      const fileWrap = document.getElementById('rp-scan-file');
      const fileName = document.getElementById('rp-scan-file-name');
      const submit = document.getElementById('rp-scan-submit');
      const form = document.getElementById('rp-scan-form');

      if (!input || !drop || !img || !fileWrap || !fileName || !submit || !form) return;

      const title = document.getElementById('rp-scan-title');
      const sub = document.getElementById('rp-scan-sub');
      const hint = document.getElementById('rp-scan-hint');

      function setEmpty() {
        drop.classList.remove('is-filled');

        img.src = img.dataset.emptySrc || img.src;

        if (title) title.hidden = false;
        if (sub) sub.hidden = false;
        if (hint) hint.hidden = false;

        fileWrap.hidden = true;
        fileName.textContent = '';

        submit.disabled = true;
        submit.textContent = 'Analyser la recette';
      }

      function setFilled(files) {
        drop.classList.add('is-filled');

        img.src = img.dataset.filledSrc || img.src;

        if (title) title.hidden = true;
        if (sub) sub.hidden = true;
        if (hint) hint.hidden = true;

        fileWrap.hidden = false;

        const names = Array.from(files || []).map(function (file) {
          return file.name;
        });

        if (names.length === 1) {
          fileName.textContent = '— ' + names[0];
        } else if (names.length > 1) {
          fileName.textContent = '— ' + names.length + ' photos sélectionnées';
        } else {
          fileName.textContent = '';
        }

        submit.disabled = false;
        submit.textContent = 'Analyser la recette';
      }

      setEmpty();

      input.addEventListener('change', function () {
        const files = input.files ? Array.from(input.files) : [];
        if (!files.length) {
          setEmpty();
          return;
        }

        setFilled(files);
      });

      form.addEventListener('submit', function () {
        submit.disabled = true;
        submit.textContent = 'Analyse en cours…';
      });

      const modal = document.getElementById('rp-scan-error-modal');
      const cancelBtn = document.getElementById('rp-scan-error-cancel');
      const retryBtn = document.getElementById('rp-scan-error-retry');
      const closeTopBtn = document.getElementById('rp-scan-error-close-top');

      function closeModal() {
        if (!modal) return;
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
      }

      function reopenPicker() {
        closeModal();

        input.value = '';
        setEmpty();

        window.setTimeout(function () {
          input.click();
        }, 120);
      }

      if (cancelBtn) {
        cancelBtn.addEventListener('click', closeModal);
      }

      if (closeTopBtn) {
        closeTopBtn.addEventListener('click', closeModal);
      }

      if (retryBtn) {
        retryBtn.addEventListener('click', reopenPicker);
      }

      if (modal) {
        modal.addEventListener('click', function (event) {
          if (event.target === modal) {
            closeModal();
          }
        });

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape' && modal.classList.contains('is-open')) {
            closeModal();
          }
        });
      }
    })();
  </script>

{% endblock %}