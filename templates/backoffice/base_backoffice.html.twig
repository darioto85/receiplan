<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <title>{% block title %}{{ page_title|default('Backoffice') }} - Kuko{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="icon" href="{{ asset('favicon.ico') }}" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('favicon-16x16.png') }}">
    <link rel="apple-touch-icon" href="{{ asset('apple-touch-icon.png') }}">
    <link rel="manifest" href="{{ asset('site.webmanifest') }}">

    <meta name="theme-color" content="#deeed9">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Kuko">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,200..1000;1,200..1000&display=swap" rel="stylesheet">

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    {% block stylesheets %}
      <link rel="stylesheet" href="{{ asset('styles/styles.css') }}">
    {% endblock %}

    {% block javascripts %}
      {{ importmap('app') }}
    {% endblock %}
  </head>

  <body class="bo-body">
    <div class="bo-layout">
      <aside class="bo-sidebar">
        <div class="bo-sidebar-inner">
          <div class="bo-brand">
            <a href="{{ path('backoffice_dashboard') }}" class="bo-brand-link text-decoration-none">
              <img class="bo-brand-logo" src="{{ asset('img/logo.png') }}" alt="Kuko">
              <div>
                <div class="bo-brand-title">Kuko</div>
                <div class="bo-brand-subtitle">Godmode</div>
              </div>
            </a>
          </div>

          <nav class="bo-nav" aria-label="Navigation backoffice">
            <a
              href="{{ path('backoffice_dashboard') }}"
              class="bo-nav-link {{ current_menu|default('dashboard') == 'dashboard' ? 'is-active' : '' }}"
            >
              <i class="fa-solid fa-chart-line bo-nav-icon"></i>
              <span>Dashboard</span>
            </a>

            <a
              href="{{ path('backoffice_users') }}"
              class="bo-nav-link {{ current_menu|default('') == 'users' ? 'is-active' : '' }}"
            >
              <i class="fa-solid fa-users bo-nav-icon"></i>
              <span>Utilisateurs</span>
            </a>

            <a
              href="{{ path('backoffice_preinscriptions') }}"
              class="bo-nav-link {{ current_menu|default('') == 'preinscriptions' ? 'is-active' : '' }}"
            >
              <i class="fa-solid fa-envelope-circle-check bo-nav-icon"></i>
              <span>Préinscriptions</span>
            </a>

            <a
              href="{{ path('backoffice_recipes') }}"
              class="bo-nav-link {{ current_menu|default('') == 'recipes' ? 'is-active' : '' }}"
            >
              <i class="fa-solid fa-book-open bo-nav-icon"></i>
              <span>Recettes</span>
            </a>

            <a
              href="{{ path('backoffice_ingredients') }}"
              class="bo-nav-link {{ current_menu|default('') == 'ingredients' ? 'is-active' : '' }}"
            >
              <i class="fa-solid fa-carrot bo-nav-icon"></i>
              <span>Ingrédients</span>
            </a>

            <a
              href="{{ path('backoffice_assistant_conversations') }}"
              class="bo-nav-link {{ current_menu|default('') == 'assistant_conversations' ? 'is-active' : '' }}"
            >
              <i class="fa-solid fa-comments bo-nav-icon"></i>
              <span>Assistant</span>
            </a>
          </nav>

          <div class="bo-sidebar-bottom">
            <a href="{{ path('meal_plan_index') }}" class="btn btn-outline-secondary w-100 mb-2">
              Retour à l’application
            </a>

            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger w-100">
              Déconnexion
            </a>
          </div>
        </div>
      </aside>

      <main class="bo-main">
        <div class="bo-main-inner">
          <header class="bo-page-header">
            <div>
              <h1 class="bo-page-title">{{ page_title|default('Backoffice') }}</h1>
              {% block backoffice_header_subtitle %}
                <p class="bo-page-subtitle mb-0">Administration Kuko</p>
              {% endblock %}
            </div>
          </header>

          {% for label, messages in app.flashes %}
            {% for message in messages %}
              <div class="alert alert-{{ label }} alert-dismissible fade show mb-3" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            {% endfor %}
          {% endfor %}

          {% block backoffice_search %}{% endblock %}

          {% block backoffice_content %}{% endblock %}
        </div>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>