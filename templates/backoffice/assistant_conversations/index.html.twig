{% extends 'backoffice/base_backoffice.html.twig' %}

{% block backoffice_search %}
    <div class="bo-search-card">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6 col-lg-5">
                <label for="q" class="form-label">Recherche</label>
                <input
                    type="text"
                    id="q"
                    name="q"
                    value="{{ q }}"
                    class="form-control"
                    placeholder="Email utilisateur..."
                >
            </div>
            <div class="col-auto">
                <button class="btn btn-success">Rechercher</button>
            </div>
            <div class="col-auto">
                <a href="{{ path('backoffice_assistant_conversations') }}" class="btn btn-outline-secondary">Réinitialiser</a>
            </div>
        </form>
    </div>
{% endblock %}

{% block backoffice_content %}
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div class="text-muted small">
            {{ total }} conversation{{ total > 1 ? 's' : '' }}
            {% if total > 0 %}
                • page {{ page }}/{{ total_pages }}
            {% endif %}
        </div>
    </div>

    <div class="bo-table-card">
        {% if conversations is empty %}
            <div class="bo-empty">Aucune conversation trouvée.</div>
        {% else %}
            <div class="table-responsive">
                <table class="table bo-table">
                    <thead>
                    <tr>
                        <th>#</th>
                        <th>Utilisateur</th>
                        <th>Jour</th>
                        <th>Créée le</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for conversation in conversations %}
                        <tr>
                            <td>{{ conversation.id }}</td>
                            <td>{{ conversation.user.email }}</td>
                            <td>{{ conversation.day|date('d/m/Y') }}</td>
                            <td>{{ conversation.createdAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <a
                                    href="{{ path('backoffice_assistant_conversations_show', {id: conversation.id}) }}"
                                    class="btn btn-sm btn-outline-primary"
                                >
                                    Voir
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    {% if total_pages > 1 %}
        <nav class="mt-4" aria-label="Pagination conversations assistant">
            <ul class="pagination justify-content-center flex-wrap">

                <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
                    <a
                        class="page-link"
                        href="{{ page > 1 ? path('backoffice_assistant_conversations', {q: q, page: page - 1}) : '#' }}"
                    >
                        Précédent
                    </a>
                </li>

                {% set start = page - 2 > 1 ? page - 2 : 1 %}
                {% set end = page + 2 < total_pages ? page + 2 : total_pages %}

                {% if start > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path('backoffice_assistant_conversations', {q: q, page: 1}) }}">1</a>
                    </li>
                    {% if start > 2 %}
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    {% endif %}
                {% endif %}

                {% for p in start..end %}
                    <li class="page-item {{ p == page ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('backoffice_assistant_conversations', {q: q, page: p}) }}">
                            {{ p }}
                        </a>
                    </li>
                {% endfor %}

                {% if end < total_pages %}
                    {% if end < total_pages - 1 %}
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    {% endif %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path('backoffice_assistant_conversations', {q: q, page: total_pages}) }}">
                            {{ total_pages }}
                        </a>
                    </li>
                {% endif %}

                <li class="page-item {{ page >= total_pages ? 'disabled' : '' }}">
                    <a
                        class="page-link"
                        href="{{ page < total_pages ? path('backoffice_assistant_conversations', {q: q, page: page + 1}) : '#' }}"
                    >
                        Suivant
                    </a>
                </li>

            </ul>
        </nav>
    {% endif %}
{% endblock %}